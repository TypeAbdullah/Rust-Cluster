# RustCluster Environment Variables

# Admin credentials (REQUIRED)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
ADMIN_USERNAME=admin

# JWT signing secret (REQUIRED - use a long random string)
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-32-chars

# Server port (default: 8080)
PORT=8080

# Directory where cloned apps are stored
APPS_DIR=./apps

# App URL (your deployment URL — used for GitHub App callback)
APP_URL=http://localhost:8080